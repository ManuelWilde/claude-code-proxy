# Required: Default API key (used as fallback for all tiers)
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Optional: Per-tier API keys (override OPENAI_API_KEY for each tier)
# This allows routing different Claude model tiers to different providers
# OPUS_API_KEY="sk-your-opus-provider-key"
# SONNET_API_KEY="sk-your-sonnet-provider-key"
# HAIKU_API_KEY="sk-your-haiku-provider-key"

# Optional: Per-tier base URLs (override OPENAI_BASE_URL for each tier)
OPENAI_BASE_URL="https://api.openai.com/v1"
# OPUS_BASE_URL="https://api.openai.com/v1"
# SONNET_BASE_URL="https://api.openai.com/v1"
# HAIKU_BASE_URL="https://api.openai.com/v1"

# Optional: Per-tier model names
# Legacy names (BIG_MODEL, MIDDLE_MODEL, SMALL_MODEL) also work
# OPUS_MODEL="gpt-4o"
# SONNET_MODEL="gpt-4o"
# HAIKU_MODEL="gpt-4o-mini"

# Legacy model mappings (still supported)
BIG_MODEL="gpt-4o"
# Used for Claude opus requests
MIDDLE_MODEL="gpt-4o"
# Used for Claude sonnet requests
SMALL_MODEL="gpt-4o-mini"
# Used for Claude haiku requests

# Optional: Per-tier Azure API versions
# OPUS_API_VERSION="2024-03-01-preview"
# SONNET_API_VERSION="2024-03-01-preview"
# HAIKU_API_VERSION="2024-03-01-preview"
# AZURE_API_VERSION="2024-03-01-preview"

# Optional: Expected Anthropic API key for client validation
ANTHROPIC_API_KEY="your-expected-anthropic-api-key"

# Optional: Server settings
HOST="0.0.0.0"
PORT="8082"
LOG_LEVEL="INFO"
# DEBUG, INFO, WARNING, ERROR, CRITICAL

# Optional: Performance settings
MAX_TOKENS_LIMIT="4096"
MIN_TOKENS_LIMIT="4096"
REQUEST_TIMEOUT="90"
MAX_RETRIES="2"

# Fabric rate gate — protects upstreams from 40+ concurrent agents.
# FABRIC_RATE_GATE="1"                # 1=enabled (default), 0=disabled
# FABRIC_RATE_MAX_INFLIGHT="8"        # max concurrent requests per upstream host
# FABRIC_RATE_SOFT_BACKOFF_S="5.0"    # floor for soft-429 retry delay

# Examples for other providers:

# Mix providers: Route opus to OpenAI, sonnet to Groq, haiku to local
# OPENAI_API_KEY="sk-openai-key"
# OPUS_MODEL="gpt-4o"
# SONNET_API_KEY="gsk_groq-key"
# SONNET_BASE_URL="https://api.groq.com/openai/v1"
# SONNET_MODEL="llama-3.1-70b-versatile"
# HAIKU_API_KEY="dummy-key"
# HAIKU_BASE_URL="http://localhost:11434/v1"
# HAIKU_MODEL="llama3.1:8b"

# For Azure OpenAI:
# OPENAI_API_KEY="your-azure-api-key"
# OPENAI_BASE_URL="https://your-resource-name.openai.azure.com/openai/deployments/your-deployment-name"
# AZURE_API_VERSION="2024-03-01-preview"
# BIG_MODEL="gpt-4"
# MIDDLE_MODEL="gpt-4"
# SMALL_MODEL="gpt-35-turbo"

# For local models (like Ollama):
# OPENAI_API_KEY="dummy-key"
# OPENAI_BASE_URL="http://localhost:11434/v1"
# BIG_MODEL="llama3.1:70b"
# MIDDLE_MODEL="llama3.1:70b"
# SMALL_MODEL="llama3.1:8b"

# Custom Headers Configuration
# Format: CUSTOM_HEADER_KEY=header_value
# CUSTOM_HEADER_AUTHORIZATION="Bearer your-token"
# CUSTOM_HEADER_X_API_KEY="your-api-key"
